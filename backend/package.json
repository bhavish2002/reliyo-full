{
  "name": "reliyo-api",
  "version": "0.1.0",
  "private": true,
  "description": "Reliyo API — NestJS modular monolith (Sprint 2 foundation)",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "prestart:dev": "npm run kill-port",
    "start:dev": "nest start --watch",
    "kill-port": "powershell -ExecutionPolicy Bypass -File scripts/kill-port.ps1",
    "clear-otp": "node scripts/clear-otp-rate-limit.mjs",
    "clear-otp:all": "node scripts/clear-otp-rate-limit.mjs --all",
    "validate:lifecycle": "node scripts/validate-lifecycle.mjs",
    "start:dev:clean": "npm run kill-port && npm run start:dev",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "prisma:generate": "dotenv -e .env -e .env.local -- prisma generate",
    "prisma:migrate": "dotenv -e .env -e .env.local -- prisma migrate dev",
    "prisma:deploy": "dotenv -e .env -e .env.local -- prisma migrate deploy",
    "prisma:studio": "dotenv -e .env -e .env.local -- prisma studio",
    "prisma:seed": "dotenv -e .env -e .env.local -- prisma db seed"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "@prisma/client": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.12",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
