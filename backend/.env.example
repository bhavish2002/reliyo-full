# Environment: development | staging | production
NODE_ENV=development
PORT=4000

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://reliyo:reliyo@localhost:5432/reliyo?schema=public

# Redis (reserved for future BullMQ / cache; not wired in Sprint 2 baseline)
