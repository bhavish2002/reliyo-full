# Copy to .env (required for Prisma CLI) and optionally .env.local (Nest overrides):
#   cp .env.example .env
#
# Environment: development | staging | production
NODE_ENV=development
PORT=4000
LOG_FORMAT=text

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://reliyo:reliyo@localhost:5433/reliyo?schema=public

# Redis (reserved for future BullMQ / cache; not wired in Sprint 2 baseline)
REDIS_URL=

# API
API_PREFIX=api/v1

# CORS (comma-separated origins; default localhost:8080)
CORS_ORIGIN=http://localhost:8080

# JWT (change secrets in staging/production)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_TTL_SEC=604800
JWT_ACCESS_TTL_SEC=900

# OTP: dev | twilio
OTP_PROVIDER=dev
# Optional fixed code in non-production for automated testing
OTP_DEV_FIXED_CODE=
# Max OTP sends per phone per hour (default: 30 dev, 5 production)
OTP_MAX_SENDS_PER_HOUR=

# Twilio (when OTP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
